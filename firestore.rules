rules_version = '2';
// DayAdapt Firestore — custom JWT auth via backend.
// Only the backend (Admin SDK) accesses Firestore; client uses REST API with Bearer token.
// So we deny direct client access. Deploy with: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if false;
    }
    match /wardrobe_items/{itemId} {
      allow read, write: if false;
    }
    match /wear_logs/{logId} {
      allow read, write: if false;
    }
    match /scans/{scanId} {
      allow read, write: if false;
    }
  }
}
